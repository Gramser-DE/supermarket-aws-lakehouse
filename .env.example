# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Instructions: Copy this file to .env and replace placeholders with your values.
# ==============================================================================

# --- Database Config ---
# Local PostgreSQL configuration
POSTGRES_USER=your_user_name
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=name_db
POSTGRES_PORT=5432
POSTGRES_HOST=name

# --- Mage AI Config ---
# The name of your Mage project folder
MAGE_PROJECT_NAME=orchestrator

# --- AWS Credentials (LocalStack) ---
# DO NOT use real AWS production keys here.
AWS_ACCESS_KEY_ID=your_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# --- Infrastructure Resources ---
KINESIS_STREAM_NAME=supermarket-sales-stream
S3_BUCKET_BRONZE=supermarket-bronze
S3_BUCKET_SILVER=supermarket-silver
S3_BUCKET_GOLD=supermarket-gold
S3_PREFIX=sales_data